# Google Books ISBN 查询
# 真实值放到 .env.local，不要提交到 Git
VITE_GOOGLE_BOOKS_API_KEY=demo-google-books-api-key

# 图片上传 API
# 留空时，前端会自动请求 http(s)://当前域名:3000/api/uploads/images
VITE_UPLOAD_ENDPOINT=

# 后端运行时配置。真实值放在 ECS 的 .env 或系统环境变量里，不要提交到 Git。
PORT=3000
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=demo-access-key-id
OSS_ACCESS_KEY_SECRET=demo-access-key-secret
OSS_PUBLIC_BASE_URL=https://your-bucket-name.oss-cn-hangzhou.aliyuncs.com
UPLOAD_MAX_FILE_SIZE=8388608
UPLOAD_MAX_FILES=30
